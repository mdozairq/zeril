    },
    "state": {
        "global": {
            "num_byte_slices": 1,
            "num_uints": 3
        },
        "local": {
            "num_byte_slices": 0,
            "num_uints": 0
        }
    },
    "schema": {
        "global": {
            "declared": {
                "employeeCount": {
                    "type": "uint64",
                    "key": "employeeCount"
                },
                "employer": {
                    "type": "bytes",
                    "key": "employer"
                },
                "totalPayrollRuns": {
                    "type": "uint64",
                    "key": "totalPayrollRuns"
                },
                "usdcAssetId": {
                    "type": "uint64",
                    "key": "usdcAssetId"
                }
            },
            "reserved": {}
        },
        "local": {
            "declared": {},
            "reserved": {}
        }
    },
    "contract": {
        "name": "Employer",
        "methods": [
            {
                "name": "initialize",
                "args": [
                    {
                        "type": "uint64",
                        "name": "usdcAsset"
                    }
                ],
                "readonly": false,
                "returns": {
                    "type": "void"
                },
                "desc": "Initialize the contract with employer and USDC asset.\nCan only be called once (when employer is not yet set)."
            },
            {
                "name": "bootstrap",
                "args": [
                    {
                        "type": "pay",
                        "name": "mbrPayment"
                    }
                ],
                "readonly": false,
                "returns": {
                    "type": "void"
                },
                "desc": "Opts the contract into the USDC ASA.\nRequires a payment to cover the MBR for the asset opt-in."
            },
            {
                "name": "addEmployee",
                "args": [
                    {
                        "type": "address",
                        "name": "employee"
                    },
                    {
                        "type": "uint64",
                        "name": "salary"
                    },
                    {
                        "type": "pay",
                        "name": "mbrPay"
                    }
                ],
                "readonly": false,
                "returns": {
                    "type": "void"
                },
                "desc": "Register a new employee with their salary.\nRequires a payment to cover box MBR."
            },
            {
                "name": "removeEmployee",
                "args": [
                    {
                        "type": "address",
                        "name": "employee"
                    }
                ],
                "readonly": false,
                "returns": {
                    "type": "void"
                },
                "desc": "Soft-delete an employee (set isActive = 0)"
            },
            {
                "name": "updateSalary",
                "args": [
                    {
                        "type": "address",
                        "name": "employee"
                    },
                    {
                        "type": "uint64",
                        "name": "newSalary"
                    }
                ],
                "readonly": false,
                "returns": {
                    "type": "void"
                },
                "desc": "Update an employee's salary"
            },
            {
                "name": "payEmployee",
                "args": [
                    {
                        "type": "address",
                        "name": "employee"
                    }
                ],
                "readonly": false,
                "returns": {
                    "type": "void"
                },
                "desc": "Pay a single employee their salary in USDC via inner transaction.\nEmployee must have opted into USDC ASA before receiving payment."
            },
            {
                "name": "getEmployee",
                "args": [
                    {
                        "type": "address",
                        "name": "employee"
                    }
                ],
                "readonly": true,
                "returns": {
                    "type": "(uint64,uint64,uint64)"
                },
                "desc": "Readonly getter for employee data"
            }
        ],
        "networks": {}
    },
    "bare_call_config": {
        "no_op": "CREATE"
    }
}