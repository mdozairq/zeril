{
    "hints": {
        "initialize(uint64)void": {
            "call_config": {
                "no_op": "CALL"
            }
        },
        "bootstrap(pay)void": {
            "call_config": {
                "no_op": "CALL"
            }
        },
        "addEmployee(address,uint64,pay)void": {
            "call_config": {
                "no_op": "CALL"
            }
        },
        "removeEmployee(address)void": {
            "call_config": {
                "no_op": "CALL"
            }
        },
        "updateSalary(address,uint64)void": {
            "call_config": {
                "no_op": "CALL"
            }
        },
        "payEmployee(address)void": {
            "call_config": {
                "no_op": "CALL"
            }
        },
        "getEmployee(address)(uint64,uint64,uint64)": {
            "read_only": true,
            "call_config": {
                "no_op": "CALL"
            },
            "structs": {
                "output": {
                    "name": "EmployeeRecord",
                    "elements": [
                        [
                            "salaryUsdcMicrounits",
                            "uint64"
                        ],
                        [
                            "isActive",
                            "uint64"
                        ],
                        [
                            "lastPaidRound",
                            "uint64"
                        ]
                    ]
                }
            }
        }
    },
    "source": {
