# Database (SQLite for local dev)
DATABASE_URL="file:./dev.db"

# API server
PORT=3001

# JWT for wallet auth (generate a long random string for production)
JWT_SECRET="change-me-in-production"

# Pinata IPFS (KYC document uploads) — use JWT *or* API key + secret
PINATA_JWT=
PINATA_API_KEY=
PINATA_SECRET_KEY=
PINATA_GATEWAY=https://gateway.pinata.cloud

# Wormhole bridge (optional custom stub URL; leave empty to simulate locally)
WORMHOLE_SANDBOX_URL=

# ── Saber Money (https://docs.saber.money/docs/quick-start-guide) ──
# Merchant API credentials (from Saber dashboard / onboarding email)
SABER_API_KEY=
SABER_API_SECRET=

# API base URL (confirm sandbox vs production with your Saber contact)
# Off-ramp quickstart examples use: https://mudrex.com/api/v1
SABER_API_BASE_URL=https://mudrex.com/api/v1

# Merchant profile (set during Saber merchant registration — reference only in app)
SABER_ORG_NAME=
SABER_ORG_DOMAIN=
SABER_ORG_EMAIL=

# Default Saber user id for sandbox testing (maps to X-User-Id on user-scoped APIs)
# Create users via Saber "Register users" API; store per-employee id in DB when integrated
SABER_SANDBOX_USER_ID=

# Legacy: custom HTTP stub for local off-ramp simulation (ignored if SABER_API_KEY is set)
SABER_SANDBOX_URL=
